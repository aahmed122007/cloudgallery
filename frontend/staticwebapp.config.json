{
  "routes": [
    { "route": "/", "rewrite": "/index.html" },
    { "route": "/login", "rewrite": "/index.html" },
    { "route": "/dashboard", "rewrite": "/dashboard.html" },
    { "route": "/upload", "rewrite": "/upload.html" },
    { "route": "/feed", "rewrite": "/feed.html" },
    { "route": "/profile", "rewrite": "/profile.html" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/css/*", "/js/*", "/*.{png,jpg,ico,svg}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
